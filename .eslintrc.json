{
  "root": true,
  "env": {
    "es2022": true,
    "mocha": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "plugins": ["import", "prettier"],
  "extends": [
    "eslint:recommended",
    "plugin:import/recommended",
    "plugin:import/errors",
    "plugin:import/warnings",
    "plugin:prettier/recommended"
  ],
  "rules": {
    "prettier/prettier": "error",
    "no-console": "warn",
    "no-debugger": "error",
    "import/no-commonjs": "error"
  },
  "settings": {
    "import/resolver": {
      "exports": true,
      "node": true
    }
  }
}
