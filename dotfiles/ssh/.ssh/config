Host *
    IdentitiesOnly yes
    IdentityFile ~/.ssh/id_pirog
    IdentityFile ~/.ssh/id_rsa

Host *.drush.in
    HostkeyAlgorithms +ssh-rsa
    PubkeyAcceptedAlgorithms +ssh-rsa

# BOTBOX1 hosts
Host botbox1 botbox1.* botbox1.tanaab.* 192.168.68.69
    User pirog
    IdentityFile ~/.ssh/id_botbox1
    IdentitiesOnly yes

# EMORI hosts (same machine, same key)
Host emori emori.* emori.tanaab.*
    User pirog
    IdentityFile ~/.ssh/id_botbox1
    IdentitiesOnly yes

# LOCAL
Host TANAABBOTBOX1 TANAABBOTBOX1.*
    User pirog
    IdentityFile ~/.ssh/id_botbox1
    IdentitiesOnly yes
