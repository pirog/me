{
  "name": "@pirog/me",
  "description": "Bootstrap script and release tooling for pirog.me.",
  "version": "0.2.1",
  "author": "Mike Pirog @pirog",
  "license": "MIT",
  "repository": "https://github.com/pirog/me",
  "bugs": "https://github.com/pirog/me/issues",
  "homepage": "https://github.com/pirog/me",
  "packageManager": "bun@1.3.4",
  "engines": {
    "bun": ">=1.3.0 <1.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^17.4.0",
    "prettier": "^3.5.3",
    "shellcheck": "^4.1.0",
    "shx": "^0.4.0",
    "ua-parser-js": "^2.0.9"
  },
  "scripts": {
    "build": "bun run build:dist && bun run build:versions",
    "build:dist": "shx rm -rf ./dist && shx mkdir -p ./dist && shx cp -f ./piroboot.sh ./brewgen.sh ./dist/",
    "build:versions": "bun ./inject-script-version.js",
    "format:check": "prettier . --check --ignore-unknown",
    "format:write": "prettier . --write --ignore-unknown",
    "lint": "bun run lint:eslint && bun run format:check && shellcheck piroboot.sh brewgen.sh",
    "lint:eslint": "eslint .",
    "sync:ai": "bun ./skills/skill-sensei/scripts/sync-ai-stow.js"
  }
}
